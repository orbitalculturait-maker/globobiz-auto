# Variabili d'ambiente per Gloobobiz Automation
GLOOBOBIZ_API_KEY=INSERISCI_LA_TUA_API_KEY
PORT=3000
TZ=Europe/Rome

# Se true, applica automaticamente il turno della data corrente ogni giorno alle 00:05 Europe/Rome
AUTO_APPLY_DAILY=false

# Se true, dopo la scrittura rilegge WM_GetListIncomingNumber e blocca l'operazione se il piano non torna
VERIFY_AFTER_WRITE=true
